  {
    "id": "fn_prepare_reading",
    "type": "function",
    "z": "flow_iot",
    "name": "Prepare reading",
    "func": "const value = Number(msg.payload.value);\nif (!Number.isFinite(value)) return null;\n\nconst timestamp = Number(msg.payload.timestamp) || Math.floor(Date.now() / 1000);\nconst receivedAt = new Date().toISOString();\n\nconst live = {\n    payload: value,\n    topic: 'Temperature',\n    reading: { value, timestamp, receivedAt }\n};\n\nconst insert = {\n    topic: `INSERT INTO readings (value, device_timestamp, received_at) VALUES (${value}, ${timestamp}, '${receivedAt}');`\n};\n\nreturn [live, insert];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 530,
    "y": 180,
    "wires": [
      [
        "ui_gauge_temperature",
        "ui_chart_temperature",
        "debug_live"
      ],
      [
        "sqlite_insert"
      ]
    ]
  },
  {
    "id": "sqlite_insert",
    "type": "sqlite",
    "z": "flow_iot",
    "mydb": "sqlite_db",
    "sqlquery": "msg.topic",
    "sql": "",
    "name": "Save reading",
    "x": 780,
