  {
    "id": "fn_render_history",
    "type": "function",
    "z": "flow_iot",
    "name": "Render history",
    "func": "const rows = Array.isArray(msg.payload) ? msg.payload : [];\n\nconst table = { payload: rows.slice().reverse() };\nconst chartMessages = rows.map((row) => ({\n    payload: Number(row.value),\n    topic: 'Temperature',\n    timestamp: Number(row.device_timestamp) * 1000\n}));\n\nreturn [table, chartMessages];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 610,
    "y": 320,
    "wires": [
      [
        "ui_history_template"
      ],
      [
        "ui_chart_temperature"
      ]
    ]
  },
