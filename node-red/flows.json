  {
    "id": "ui_history_template",
    "type": "ui_template",
    "z": "flow_iot",
    "group": "ui_group_history",
    "name": "History table",
    "order": 2,
    "width": 12,
    "height": 5,
    "format": "<table style=\"width:100%; border-collapse: collapse;\">\n  <thead>\n    <tr>\n      <th style=\"text-align:left; padding: 6px;\">Value</th>\n      <th style=\"text-align:left; padding: 6px;\">Device timestamp</th>\n      <th style=\"text-align:left; padding: 6px;\">Received</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr ng-repeat=\"row in msg.payload\">\n      <td style=\"padding: 6px; border-top: 1px solid #ddd;\">{{row.value | number:1}} C</td>\n      <td style=\"padding: 6px; border-top: 1px solid #ddd;\">{{row.device_timestamp * 1000 | date:'yyyy-MM-dd HH:mm:ss'}}</td>\n      <td style=\"padding: 6px; border-top: 1px solid #ddd;\">{{row.received_at | date:'yyyy-MM-dd HH:mm:ss'}}</td>\n    </tr>\n  </tbody>\n</table>",
    "storeOutMessages": true,
    "fwdInMessages": true,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 640,
    "y": 320,
    "wires": [
      []
    ]
