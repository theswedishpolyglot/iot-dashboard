  {
    "id": "trigger_refresh_history",
    "type": "change",
    "z": "flow_iot",
    "name": "Select latest history",
    "rules": [
      {
        "t": "set",
        "p": "topic",
        "pt": "msg",
        "to": "SELECT value, device_timestamp, received_at FROM readings WHERE device_timestamp >= strftime('%s','now','-30 minutes') ORDER BY device_timestamp ASC;",
        "tot": "str"
      }
    ],
    "action": "",
    "property": "",
    "from": "",
    "to": "",
    "reg": false,
    "x": 1010,
    "y": 220,
    "wires": [
      [
        "sqlite_history"
      ]
    ]
  },
  {
    "id": "inject_history",
    "type": "inject",
    "z": "flow_iot",
    "name": "Load history",
    "props": [
      {
        "p": "topic",
        "vt": "str"
      }
    ],
    "repeat": "10",
    "crontab": "",
    "once": true,
    "onceDelay": "1",
    "topic": "SELECT value, device_timestamp, received_at FROM readings WHERE device_timestamp >= strftime('%s','now','-30 minutes') ORDER BY device_timestamp ASC;",
